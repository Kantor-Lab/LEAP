<?xml version="1.0" encoding="utf-8"?>
<robot name="amiga_sim" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Import the pure hardware URDF -->
  <xacro:include filename="$(find leap_desc)/urdf/amiga_base.xacro" />

  <!-- Gazebo Camera Sensor: FLIR Blackfly S USB3 -->
  <gazebo reference="camera">
    <sensor name="camera" type="camera">
      <camera>
        <camera_info_topic>camera/camera_info</camera_info_topic>
        <horizontal_fov>1.5708</horizontal_fov>  <!-- this is 90 degrees, check against real sensor -->
        <image>
          <width>1440</width>
          <height>1080</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <gz_frame_id>blackfly_optical</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo LiDAR Sensor: Ouster OS0 Rev 7 -->
  <gazebo reference="os_sensor">
    <sensor name='gpu_lidar' type='gpu_lidar'>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <!-- OS0 True Horizontal: 360 degrees -->
          <horizontal>
            <samples>1024</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <!-- OS0 True Vertical: 45 degrees (will be flattened to 1 layer for 2D Nav2) -->
          <vertical>
            <samples>64</samples>
            <resolution>1</resolution>
            <min_angle>-0.3926991</min_angle> <!-- -22.5 degrees -->
            <max_angle>0.3926991</max_angle>  <!-- +22.5 degrees -->
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>35.0</max>
          <resolution>0.003</resolution>
        </range>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <gz_frame_id>os_sensor</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo IMU Sensor (Simulating the Ouster's internal IMU) -->
  <gazebo reference="os_sensor">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
      <gz_frame_id>os_sensor</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo GPS Sensor: Emlid Reach M2 -->
  <gazebo reference="RTK_gnss">
    <sensor name="reach_m2_navsat" type="navsat">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>gps/fix</topic>
      <gz_frame_id>RTK_gnss</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- Gazebo ros2_control Hardware Interface -->
  <!-- Since the real robot uses a CAN black box, this is only needed in simulation -->
  <ros2_control name="IgnitionSystemTest" type="system">
    <hardware>
      <plugin>ign_ros2_control/IgnitionSystem</plugin>
    </hardware>
    <joint name="FL_wheel_j">
      <command_interface name="velocity" />
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="FR_wheel_j">
      <command_interface name="velocity" />
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="RL_wheel_j">
      <command_interface name="velocity" />
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="RR_wheel_j">
      <command_interface name="velocity" />
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <!-- Gazebo ros2_control Plugin -->
  <!-- Points directly to the YAML file in the leap_sim package -->
  <gazebo>
    <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find leap_sim)/config/diff_controller.yaml</parameters>
    </plugin>
  </gazebo>

</robot>